names_to = "dataset",
values_to = "rmse")
p6 <- rmsesL %>%
ggplot(aes( span, rmse, col = dataset) ) +
geom_line() +
labs(x = "Span", y = "RMSE", color = "Dataset",
title = "Comparing span performance on training vs. test data RMSE") +
scale_color_manual(values = c("red", "blue"),
labels = c("Test RMSE", "Train RMSE"))
