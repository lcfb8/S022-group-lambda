# mice imputation
# Checking missingness rates for key variables
missing_rates <- survey_clean %>%
    summarise(across(everything(), 
                     ~mean(is.na(.)))) %>%
    pivot_longer(everything(), 
                 names_to  = "variable", 
                 values_to = "missing_rate") %>%
    arrange(desc(missing_rate))

print(missing_rates)

# View all variables with any missingness
missing_rates %>%
    filter(missing_rate > 0) %>%
    print(n = Inf)

# using mean imputation for low missingness numeric variables, excluding bully and student_id
low_missing_vars <- missing_rates %>%
    filter(missing_rate > 0 & missing_rate < 0.10) %>%
    pull(variable)
cat("Low missingness variables (mean/mode imputation):\n")
print(low_missing_vars)

# Mode function for categorical variables
impute_mode <- function(x) {
    mode_val <- names(sort(table(x), decreasing = TRUE))[1]
    x[is.na(x)] <- mode_val
    return(x)
}

# Apply to low-missingness variables
survey_clean <- survey_clean %>%
    mutate(
        # Mean imputation for numeric variables
        across(
            all_of(low_missing_vars) & where(is.numeric),
            ~ifelse(is.na(.), mean(., na.rm = TRUE), .)
        ),
        # Mode imputation for factor/character variables
        across(
            all_of(low_missing_vars) & where(is.factor),
            ~impute_mode(.)
        )
    )

# Verify low missingness variables are now clean
survey_clean %>%
    select(all_of(low_missing_vars)) %>%
    summarise(across(everything(), ~sum(is.na(.)))) %>%
    pivot_longer(everything(),
                 names_to  = "variable",
                 values_to = "n_missing")

# mice imputation for variables with higher missingness rates, excluding bully and student_id
high_missing_vars <- missing_rates %>%
    filter(missing_rate >= 0.10) %>%
    pull(variable)
cat("\nHigh missingness variables (MICE):\n")
print(high_missing_vars)

library(mice)

# Pull out only the columns that need MICE imputation
# Include student_id so we can merge back later
survey_mice_input <- survey_clean %>%
    select(student_id, all_of(high_missing_vars))

# Run MICE imputation
# m = number of imputed datasets (5 is standard)
# maxit = number of iterations
# method = "pmm" (predictive mean matching) works well for numeric
mice_output <- mice(
    survey_mice_input %>% select(-student_id),
    m     = 5,
    maxit = 10,
    method = "pmm",
    seed  = 123,
    printFlag = FALSE  # suppress verbose output
)

# Extract one completed dataset (the first imputed version)
survey_imputed <- complete(mice_output, action = 1)

# Add student_id back
survey_imputed <- bind_cols(
    survey_mice_input %>% select(student_id),
    survey_imputed
)

# Merge imputed values back into main dataset
# First drop the original high-missing columns
survey_clean <- survey_clean %>%
    select(-all_of(high_missing_vars)) %>%
    left_join(survey_imputed, by = "student_id")


