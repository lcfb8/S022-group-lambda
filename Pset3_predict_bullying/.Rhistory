set.seed(8675309)
library(tidyverse)
dat = read_csv( "SF_Comp_2017.csv" )
dat %>%
ggplot(aes(x = total_comp)) +
geom_histogram() + theme_bw(base_size = 18) +
labs(x = "Total Annual Compensation ($)", y = "",
title = "Total Compensation in San Francisco in 2017",
caption = "Source: DataSF") +
scale_x_continuous(labels = scales::dollar)
smp <- sample_n( dat, 100 )
smp
mean( smp$total_comp )
# our error in our estimation
mean( smp$total_comp ) - mean( dat$total_comp )
# put pieces together
res = dat %>%
sample_n(size = 100) %>%  # sample N data points
summarize(mean = mean(total_comp))  # take the mean
res$mean
# Simple wrapper function
get_sample_mean <- function(sample_size = 100){
res = dat %>%
sample_n(size = sample_size) %>%  # sample N data points
summarize(mean = mean(total_comp))  # take the mean
res$mean
}
get_sample_mean( 100 )
get_sample_mean( 100 )
get_sample_mean( 100 )
# We 1000 times sample from our data and analyze our sample.
# We can then see how accurate a sample is going to be!
n_sims <- 1000
sim_out <- replicate( n_sims, get_sample_mean( sample_size = 100 ) )
sim_out
sim_out = data.frame( sample_means = sim_out )
ggplot( sim_out, aes(x = sample_means)) +
geom_histogram( binwidth = 1000 ) +
theme_bw(base_size = 18) +
labs(x = "Average Annual Compensation ($)", y = "",
title = "Estimated Avg. Comp. from Samples of 100",
caption = "Source: DataSF") +
scale_x_continuous(labels = scales::dollar,
limits = c(40000, 80000)) +
geom_vline(data = sim_out %>% summarize(global_mean = mean(sample_means)),
aes(xintercept = global_mean),
color = "red")
# This is the Standard Error
sd( sim_out$sample_means )
# our sample
smp
mean( smp$total_comp )
mod = lm( total_comp ~ 1, data = smp )
summary( mod )
summary(dat$total_comp)
sd(dat$total_comp)
# This is the Standard Error
sd( sim_out$sample_means )
