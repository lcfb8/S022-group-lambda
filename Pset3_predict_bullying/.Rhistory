library( tidyverse )
counts = tibble::tribble(
~method,    ~first, ~second, ~skipped, ~`super bad`,
"BNS",         10L,      6L,      54L,     29L,
"co-occur",    50L,     12L,      28L,      9L,
"FDR",         15L,      3L,      78L,     11L,
"L1LR",        60L,      8L,      21L,      3L,
"tfidf",       37L,      8L,      48L,      6L
)
counts
counts %>%
rename( "bad" = "`super bad`")
counts %>%
rename( "bad" = `super bad`)
counts
counts <- counts %>%
rename( "bad" = `super bad`)
counts
counts %>%
summarise( sum( first ), mean( bad ) )
counts %>%
mutate( "good" = first + second )
counts
counts %>%
mutate( "good" = first + second )
counts
counts <- counts %>%
mutate( "good" = first + second )
counts
counts <- counts %>%
mutate( "score" = good / (skipped + bad))
counts
count_mini <- counts %>%
filter( bad > 10 )
count_mini
count_mini <- counts %>%
filter( bad <= 10 )
count_mini
counts %>%
arrange( desc( first ) )
stats = tibble::tribble(
~method, ~type,
"BNS",      "count",
"co-occur", "count",
"L1LR",     "regression",
"tfidf",    "count",
"random",   NA
)
stats
counts_stats = left_join( counts, stats )
counts_stats
counts_stats = left_join( counts, stats, join_by = "method" )
counts_stats = left_join( counts, stats, by = "method" )
counts_stats
counts_stats = left_join( counts, stats, by = "method", NA = "unknown" )
counts_stats
counts_stats = left_join( counts, stats, by = "method" )
counts_stats
