names(unemploy_brazil)
unemploy_brazil$m_y
#why is unemploy_brazil$m_y two columns?
#because when we created the m_y column, we used bind_cols which creates a new data frame with two columns, one for month.2 and one for year. So instead of creating a single column that combines month.2 and year, it created two separate columns in a new data frame called m_y. To fix this, we should use the paste function to combine month.2 and year into a single string, and then assign that string to the m_y column.
#ok let's do this
unemploy_brazil = unemploy_brazil %>%
mutate(m_y = paste(month.2, year, sep = "_"))
unemploy_brazil
