unemploy_brazil = unemploy_brazil %>%
mutate(m_y = case_when(
month.2 == "fev" ~ paste(2, year, sep = "_"),
month.2 == "mar" ~ paste(3, year, sep = "_"),
month.2 == "abr" ~ paste(4, year, sep = "_"),
month.2 == "mai" ~ paste(5, year, sep = "_"),
month.2 == "jun" ~ paste(6, year, sep = "_"),
month.2 == "jul" ~ paste(7, year, sep = "_"),
